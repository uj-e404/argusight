# ArguSight Environment Variables

# Server port (default: 3000)
PORT=3000

# Path to config directory (default: ./config)
# CONFIG_PATH=/etc/argusight/config

# Node environment
NODE_ENV=development

# SSH passwords can be referenced from env vars in servers.json
# Example: set password to "$ENV:SSH_PASS_SERVER1" in config
# SSH_PASS_SERVER1=your_password_here
